<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/android:windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_tela_editar"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginBottom="24dp" />

    <ImageView
        android:id="@+id/imgEditarFoto"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:scaleType="centerCrop"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAlterarFoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alterar Foto"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_titulo"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground" />

    <EditText
        android:id="@+id/edtEditarTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="?attr/colorOnBackground"
        android:textColorHint="?attr/colorOnBackground"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_descricao"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground" />

    <EditText
        android:id="@+id/edtEditarDescricao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lines="4"
        android:gravity="top"
        android:padding="12dp"
        android:textColor="?attr/colorOnBackground"
        android:textColorHint="?attr/colorOnBackground"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Data"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtEditarPrazoData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: 29/06/2026"
                android:padding="12dp"
                android:inputType="date"
                android:textColor="?attr/colorOnBackground"
                android:textColorHint="?attr/colorOnBackground" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Hora"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtEditarPrazoHora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: 14:00"
                android:padding="12dp"
                android:inputType="time"
                android:textColor="?attr/colorOnBackground"
                android:textColorHint="?attr/colorOnBackground" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnSalvarAlteracao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_salvar_alteracoes"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnExcluirLembrete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_excluir"
        android:backgroundTint="@color/alerta_deletar"
        android:textColor="@color/white"
        android:layout_marginBottom="4dp"/>

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Voltar"
        android:backgroundTint="#E0E0E0"
        android:textColor="#333333"/>

</LinearLayout>